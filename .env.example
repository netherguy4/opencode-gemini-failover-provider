# Comma-separated Gemini API keys.
# Use keys with valid access/billing. Example:
# GEMINI_API_KEYS=AIza...,AIza...,AIza...
GEMINI_API_KEYS=key1,key2,key3

# Local bearer token used only between OpenCode and this local provider.
LOCAL_PROVIDER_KEY=local-dev-key

# Gemini model used when model is missing, or always when FORCE_DEFAULT_MODEL=true.
DEFAULT_MODEL=gemini-flash-latest
FORCE_DEFAULT_MODEL=false

# Host/port inside Node server.
# Docker should normally use HOST=0.0.0.0.
# Local non-Docker usage can use HOST=127.0.0.1.
HOST=0.0.0.0
PORT=8787

# Host interface exposed by Docker on the host machine.
# 127.0.0.1 = only this machine can access the provider.
# 0.0.0.0 = expose on LAN/server interfaces. Use firewall/auth carefully.
PUBLISHED_HOST=127.0.0.1

# Failover behavior.
MAX_ATTEMPTS_PER_REQUEST=3
KEY_COOLDOWN_MS=60000
UPSTREAM_TIMEOUT_MS=300000

# Optional: control Gemini thinking via OpenAI-compatible reasoning_effort.
# Allowed: none, minimal, low, medium, high.
# For Gemini 3 / gemini-flash-latest, use minimal/low/medium/high; "none" is mainly for Gemini 2.5 models.
REASONING_EFFORT=
FORCE_REASONING_EFFORT=false

# Gemini tool calling: thought_signature fallback.
# true  = if client dropped thought_signature, inject Google's documented dummy value
# false = only pass/preserve real signatures; missing signature can cause tool-call 400 errors
THOUGHT_SIGNATURE_DUMMY_FALLBACK=true
THOUGHT_SIGNATURE_CACHE_TTL_MS=1800000
THOUGHT_SIGNATURE_CACHE_MAX_ENTRIES=10000
