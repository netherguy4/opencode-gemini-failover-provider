# =============================================================================
# Required: Comma-separated Gemini API keys
# =============================================================================
GEMINI_API_KEYS=key1,key2,key3

# =============================================================================
# Local provider auth
# =============================================================================
LOCAL_PROVIDER_KEY=local-dev-key

# =============================================================================
# Model defaults
# =============================================================================
DEFAULT_MODEL=gemini-flash-latest
FORCE_DEFAULT_MODEL=false

# =============================================================================
# Host / port
# =============================================================================
HOST=0.0.0.0
PORT=8787
PUBLISHED_HOST=127.0.0.1

# =============================================================================
# Failover behavior
# =============================================================================
MAX_ATTEMPTS_PER_REQUEST=3
KEY_COOLDOWN_MS=60000
UPSTREAM_TIMEOUT_MS=300000

# =============================================================================
# Reasoning / thinking level
# =============================================================================
REASONING_EFFORT=
FORCE_REASONING_EFFORT=false

# =============================================================================
# Gemini tool calling: thought_signature fallback
# =============================================================================
THOUGHT_SIGNATURE_DUMMY_FALLBACK=true
THOUGHT_SIGNATURE_CACHE_TTL_MS=1800000
THOUGHT_SIGNATURE_CACHE_MAX_ENTRIES=10000

# =============================================================================
# Debugging / observability
# =============================================================================
# Log request metadata (route, model, message count, attachment types/sizes).
# Does NOT log full prompts, file contents, or base64 data.
DEBUG_REQUEST_SHAPES=false

# Log normalized payload structure (model, stream flag, message roles, content
# shapes, image sizes). Does NOT log message text or base64 contents.
DEBUG_NORMALIZED_PAYLOADS=false

# Enable the GET /debug/model-version endpoint to check which concrete model
# version Gemini resolves for a given alias. Protected by local provider auth.
DEBUG_UPSTREAM_MODEL_VERSION=false

# =============================================================================
# Multimodal feature flags
# =============================================================================
# Enable image/vision processing (image_url parts, Ollama images[]).
ENABLE_VISION=true

# Advertise "vision" capability in /api/show (for Ollama/Copilot clients).
ADVERTISE_VISION=true

# Enable local text extraction from file attachments (PDF, DOCX, XLSX, TXT, ...).
# When disabled, file attachments are rejected with a 400 error.
ENABLE_FILE_TEXT_EXTRACTION=true

# Enable remote file URL fetching. DISABLED by default for security.
# When disabled, remote URLs return a clear error.
ENABLE_REMOTE_FILE_FETCH=false

# Enable native Gemini Files API path for audio/video/large files.
# DISABLED by default — implementing this requires response format conversion.
ENABLE_NATIVE_GEMINI_FILES=false

# =============================================================================
# Safety limits
# =============================================================================
# Maximum request body size in bytes (default: 100 MB).
MAX_REQUEST_BODY_BYTES=104857600

# Maximum size per image attachment in bytes (default: 20 MB).
MAX_IMAGE_BYTES=20971520

# Maximum size per file attachment in bytes (default: 50 MB).
MAX_FILE_BYTES=52428800

# Maximum total attachment bytes across all images/files in one request.
MAX_TOTAL_ATTACHMENT_BYTES=104857600

# Maximum characters of extracted file text to include in the prompt.
FILE_TEXT_MAX_CHARS=200000

# Timeout for remote file fetching (when enabled).
REMOTE_FETCH_TIMEOUT_MS=10000

# =============================================================================
# Upstream error handling
# =============================================================================

# Maximum number of different keys to try before giving up on a request that
# gets repeated 500s from upstream. Prevents burning all API keys on
# deterministic payload/model incompatibilities.
MAX_UPSTREAM_500_FAILOVER_ATTEMPTS=2

# How long (ms) to remember a request fingerprint that has seen upstream 500s
# before forgetting it. Resets after this TTL so transient issues can retry.
UPSTREAM_500_FINGERPRINT_TTL_MS=300000

# Maximum characters of upstream error body to include in logs.
# Does NOT log prompt text, base64 data, or API keys. Limited to error details.
UPSTREAM_ERROR_LOG_SNIPPET_CHARS=2000

# =============================================================================
# Model capability validation
# =============================================================================

# How to treat unknown models (not in the explicit capability map).
# permissive: allow all features, rely on 500 fingerprint guard for detection.
# conservative: reject risky features (images, tools, reasoning) unless the
#   model is explicitly known to support them.
UNKNOWN_MODEL_CAPABILITY_MODE=permissive

# Gemma models are conservative by default (no vision, no tools, no reasoning).
# Set these to true if you know your Gemma model supports these features.
GEMMA_ALLOW_VISION=false
GEMMA_ALLOW_TOOLS=false
GEMMA_ALLOW_REASONING_EFFORT=false
